# Application
APP_ENV=development
LOG_LEVEL=INFO
APP_VERSION=1.0.0

# Data paths
DATA_DIR=data
DUCKDB_PATH=data/worldcup.duckdb
DUCKDB_BASELINE_PATH=data/bootstrap/worldcup.duckdb
RAW_DATA_DIR=data/raw/worldcups
WORKING_DATA_DIR=data/working

# OpenFootball source
OPENFOOTBALL_GITHUB_REF=master
OPENFOOTBALL_BASE_URL=https://raw.githubusercontent.com/openfootball/worldcup.json

# Runtime refresh (production)
REFRESH_DATA_ON_START=false
DATA_FRESHNESS_WARNING_HOURS=36

# Frontend dev proxy target
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
